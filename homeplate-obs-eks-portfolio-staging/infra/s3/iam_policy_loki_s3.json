{
  "Version": "2012-10-17",
  "Statement": [
    { "Sid": "LokiList", "Effect": "Allow", "Action": ["s3:ListBucket"], "Resource": ["arn:aws:s3:::hp-loki-chunks","arn:aws:s3:::hp-loki-ruler"] },
    { "Sid": "LokiRW", "Effect": "Allow", "Action": ["s3:GetObject","s3:PutObject","s3:DeleteObject","s3:AbortMultipartUpload","s3:ListMultipartUploadParts"],
      "Resource": ["arn:aws:s3:::hp-loki-chunks/*","arn:aws:s3:::hp-loki-ruler/*"] }
  ]
}