{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAiopsAppSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:ap-northeast-2:<aws-account-id>:secret:aiops/rds/aiops-postgres/app-*"
    }
  ]
}
