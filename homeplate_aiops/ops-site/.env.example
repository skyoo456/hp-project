# Auth.js (NextAuth) — required
AUTH_SECRET=
# Production (e.g. behind reverse proxy)
AUTH_TRUST_HOST=true

# Keycloak
KEYCLOAK_ISSUER=https://auth.homeplate.site/realms/homeplate
KEYCLOAK_CLIENT_ID=aiops-web
KEYCLOAK_CLIENT_SECRET=

# App URL (로컬: http://localhost:3000, 운영: https://aiops.homeplate.site)
NEXTAUTH_URL=https://aiops.homeplate.site

# Optional: 백엔드 API base (미설정 시 상대경로 /api 사용)
# NEXT_PUBLIC_API_BASE_URL=
